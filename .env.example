# geohazard-chat environment (SS6.6 complete MVP list)
# Copy to .env and fill in. Never commit .env.

# --- LLM (SS8) ---
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1:8b-instruct-q5_K_M
# External Ollama host (Proxmox VM with RTX 3050 passthrough), or
# http://llm:11434 if you enable the sidecar in docker-compose.yml
OLLAMA_BASE_URL=http://192.168.1.50:11434

# --- Data-source credentials ---
CDSE_USERNAME=
CDSE_PASSWORD=
EARTHDATA_USERNAME=
EARTHDATA_PASSWORD=

# --- Infrastructure secrets (required) ---
POSTGRES_PASSWORD=
RABBITMQ_DEFAULT_PASS=

# --- Limits & retention (SS4.3 derived) ---
DATA_RETENTION_DAYS=30
MAX_AOI_KM2=1000
MAX_AOI_KM2_EXPERT=5000
WORKER_CONCURRENCY=2
DOWNLOAD_CONCURRENCY=2
EXPERT_RAW_PROCESSING=false
SCRATCH_MIN_FREE_GB=100
# Set SCRATCH_MIN_FREE_GB=600 when EXPERT_RAW_PROCESSING=true (SS6.6)
