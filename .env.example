# geohazard-chat environment (SS6.6 complete MVP list)
# Copy to .env and fill in. Never commit .env.

# --- LLM (SS8 / amended SS6.6): any OpenAI-compatible server ---
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=http://192.168.10.150:5001/v1
LLM_API_KEY=not-needed
LLM_MODEL=koboldcpp/qwen3.5-9b-polaris-highiq-instruct-q4_k_m-imat
LLM_TIMEOUT_SECONDS=90

# --- Data-source credentials ---
CDSE_USERNAME=
CDSE_PASSWORD=
EARTHDATA_USERNAME=
EARTHDATA_PASSWORD=

# --- Infrastructure secrets (required) ---
POSTGRES_PASSWORD=
RABBITMQ_DEFAULT_PASS=

# --- Limits & retention (SS4.3 derived) ---
DATA_RETENTION_DAYS=30
MAX_AOI_KM2=1000
MAX_AOI_KM2_EXPERT=5000
WORKER_CONCURRENCY=2
DOWNLOAD_CONCURRENCY=2
EXPERT_RAW_PROCESSING=false
SCRATCH_MIN_FREE_GB=100
# Set SCRATCH_MIN_FREE_GB=600 when EXPERT_RAW_PROCESSING=true (SS6.6)
